<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.zlagoda.controller.cashier.CashierSalesController"
      spacing="12"
      style="-fx-padding: 15;">

    <!-- Верхня панель -->
    <HBox spacing="10">
        <Label text="ПРОДАЖ" style="-fx-font-size: 16; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS"/>
        <TextField promptText="Пошук товару за UPC" prefWidth="200"/>
    </HBox>

    <!-- Ввід UPC -->
    <HBox spacing="10">
        <TextField fx:id="upcField" promptText="Введіть UPC..." prefWidth="300"/>
        <Button text="Додати" onAction="#onAddProduct"/>
    </HBox>

    <!-- Чек -->
    <Label fx:id="checkNumberLabel" text="Чек №: 12345"/>

    <!-- Таблиця -->
    <TableView fx:id="table" prefHeight="250">
        <columns>
            <TableColumn text="№" prefWidth="40"/>
            <TableColumn text="UPC" prefWidth="120"/>
            <TableColumn text="Назва" prefWidth="200"/>
            <TableColumn text="К-ть" prefWidth="80"/>
            <TableColumn text="Ціна" prefWidth="100"/>
            <TableColumn text="Сума" prefWidth="120"/>
        </columns>
    </TableView>

    <!-- Нижній блок -->
    <HBox spacing="20">

        <!-- Картка клієнта -->
        <VBox spacing="8" style="-fx-border-color: lightgray; -fx-padding: 10;">
            <Label text="КАРТКА КЛІЄНТА"/>
            <TextField fx:id="cardField" prefWidth="200"/>
            <Label fx:id="discountLabel" text="Відсоток знижки: 0%"/>
        </VBox>

        <!-- Розрахунок -->
        <VBox spacing="5">
            <Label fx:id="totalLabel" text="РАЗОМ: 0"/>
            <Label fx:id="discountSumLabel" text="Знижка: 0"/>
            <Label fx:id="toPayLabel" text="До оплати: 0"/>
            <Label fx:id="vatLabel" text="в т.ч. ПДВ 20%: 0"/>
        </VBox>

    </HBox>

    <!-- Кнопки -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Скасувати" onAction="#onCancel"/>
        <Button text="Створити" onAction="#onCreate"/>
    </HBox>

</VBox>
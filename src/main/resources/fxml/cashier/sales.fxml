<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<VBox spacing="15.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.zlagoda.controller.cashier.CashierSalesController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="ПРОДАЖ">
        <font>
            <Font name="System Bold" size="18.0"/>
        </font>
        <graphic>
            <ImageView fitHeight="24.0" fitWidth="24.0" preserveRatio="true">
                <image>
                    <Image url="@/images/icons_sales.png"/>
                </image>
            </ImageView>
        </graphic>
    </Label>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <TextField fx:id="upcInputField"  prefHeight="30.0" prefWidth="300.0" promptText="ВВЕДІТЬ UPC..."/>
        <Button fx:id="addButton" onAction="#searchProductByUPC" mnemonicParsing="false" prefHeight="30.0" text="ДОДАТИ"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <Label fx:id="checkNumberLabel" text="ЧЕК № 12345">
        <font>
            <Font name="System Bold" size="14.0"/>
        </font>
    </Label>

    <TableView fx:id="salesTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="numberColumn" prefWidth="50.0" text="№"/>
            <TableColumn fx:id="upcColumn" prefWidth="120.0" text="UPC"/>
            <TableColumn fx:id="nameColumn" prefWidth="300.0" text="НАЗВА"/>
            <TableColumn fx:id="quantityColumn" prefWidth="80.0" text="К-ТЬ"/>
            <TableColumn fx:id="priceColumn" prefWidth="100.0" text="ЦІНА"/>
            <TableColumn fx:id="sumColumn" prefWidth="120.0" text="СУМА"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <HBox spacing="30.0">
        <VBox spacing="10.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;"
              HBox.hgrow="ALWAYS">
            <Label text="КАРТА КЛІЄНТА">
                <font>
                    <Font name="System Bold" size="13.0"/>
                </font>
            </Label>
            <TextField fx:id="clientCardField" promptText="Номер карти..."/>
            <HBox spacing="10.0">
                <Label text="ВІДСОТОК ЗНИЖКИ :"/>
                <Label fx:id="discountPercentLabel" text="0 %"/>
            </HBox>
        </VBox>

        <VBox spacing="8.0" HBox.hgrow="SOMETIMES">
            <GridPane hgap="20.0" vgap="5.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0"/>
                    <ColumnConstraints halignment="RIGHT" hgrow="ALWAYS" minWidth="10.0"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES"/>
                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES"/>
                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES"/>
                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES"/>
                </rowConstraints>
                <children>
                    <Label text="РАЗОМ :"/>
                    <Label fx:id="totalRawLabel" text="0.00" GridPane.columnIndex="1"/>

                    <Label text="ЗНИЖКА :" GridPane.rowIndex="1"/>
                    <Label fx:id="discountAmountLabel" text="- 0.00" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="ДО ОПЛАТИ :" GridPane.rowIndex="2">
                        <font>
                            <Font name="System Bold" size="16.0"/>
                        </font>
                    </Label>
                    <Label fx:id="totalFinalLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <font>
                            <Font name="System Bold" size="16.0"/>
                        </font>
                    </Label>

                    <Label text="в т.ч. ПДВ 20% :" GridPane.rowIndex="3">
                        <font>
                            <Font size="11.0"/>
                        </font>
                    </Label>
                    <Label fx:id="vatLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="3">
                        <font>
                            <Font size="11.0"/>
                        </font>
                    </Label>
                </children>
            </GridPane>

            <HBox alignment="BOTTOM_RIGHT" spacing="10.0" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="15.0"/>
                </padding>
                <Button fx:id="createButton" onAction="#addReciept" mnemonicParsing="false" prefWidth="130.0"
                        style="-fx-background-color: #f0f0f0; -fx-border-color: #888888; -fx-border-radius: 3;"
                        text="СТВОРИТИ"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
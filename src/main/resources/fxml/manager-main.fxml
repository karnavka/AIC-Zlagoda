<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane prefHeight="600" prefWidth="900" stylesheets="@/css/manager-main.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.zlagoda.controller.ManagerMainController">
        <top>
            <Label prefHeight="28.0" prefWidth="96.0" text="Вікно менеджера" BorderPane.alignment="CENTER" />
        </top>
   <left>
            <TabPane side="LEFT" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
                <tabs>
                    <Tab text="Працівники">
                        <content>
                            <Label text="Працівники" />
                        </content>
                    </Tab>
                    <Tab text="Клієнти">
                        <content>
                            <Label text="Клієнти" />
                        </content>
                    </Tab>
                    <Tab text="Товари">
                        <content>
                            <Label text="Товари" />
                        </content>
                    </Tab>
                    <Tab text="Чеки">
                        <content>
                            <Label text="Чеки" />
                        </content>
                    </Tab>
                    <Tab text="Звіти">
                        <content>
                            <Label text="Звіти" />
                        </content>
                    </Tab>
                </tabs>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
            </TabPane>
   </left>
    </BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600" prefWidth="900"
            stylesheets="@/css/manager-main.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.zlagoda.controller.ManagerMainController"
            styleClass="root">

    <top>
        <BorderPane styleClass="top-bar">
            <left>
                <VBox alignment="CENTER_LEFT" spacing="-2">
                    <Label text="ZLAGODA" styleClass="brand-title">
                        <font>
                            <Font name="System Bold" size="23.0"/>
                        </font>
                    </Label>

                    <Label text="МІНІСУПЕРМАРКЕТ" styleClass="brand-subtitle">
                        <font>
                            <Font name="System" size="10.0"/>
                        </font>
                    </Label>
                </VBox>
            </left>

            <right>
                <HBox alignment="CENTER"
                      spacing="10"
                      style="-fx-cursor: hand;"
                      onMouseClicked="#handleProfileClick">

                    <Label fx:id="employeeNameLabel"
                           text="Manager"
                           styleClass="employee-name"/>

                    <StackPane styleClass="profile-container">
                        <ImageView fx:id="userImageView"
                                   fitWidth="42"
                                   fitHeight="42"
                                   preserveRatio="true">
                            <image>
                                <Image url="@/images/black-cat-icon.png"/>
                            </image>
                        </ImageView>

                        <Region styleClass="profile-overlay"
                                prefWidth="42"
                                prefHeight="42"/>
                    </StackPane>
                </HBox>
            </right>
        </BorderPane>
    </top>

    <center>
        <TabPane side="LEFT"
                 tabClosingPolicy="UNAVAILABLE"
                 BorderPane.alignment="CENTER">

            <tabs>
                <Tab text="Працівники"
                     onSelectionChanged="#handleEmpTabSelected"
                     fx:id="employeesTab">
                    <content>
                        <fx:include source="manager/employees.fxml"/>
                    </content>
                </Tab>

                <Tab text="Клієнти"
                     onSelectionChanged="#handleClientTabSelected"
                     fx:id="clientsTab">
                    <content>
                        <fx:include source="manager/clients.fxml"/>
                    </content>
                </Tab>

                <Tab text="Товари"
                     onSelectionChanged="#handleProductsTabSelected"
                     fx:id="productsTab">
                    <content>
                        <fx:include source="manager/products.fxml"/>
                    </content>
                </Tab>

                <Tab text="Чеки"
                     onSelectionChanged="#handleCheckTabSelected"
                     fx:id="checkTab">
                    <content>
                        <fx:include source="manager/checks.fxml"/>
                    </content>
                </Tab>

                <Tab text="Звіти">
                    <content>
                        <fx:include source="manager/reports.fxml"/>
                    </content>
                </Tab>

                <Tab fx:id="statsTab" text="Статистика">
                    <content>
                        <fx:include source="manager/statistics.fxml"/>
                    </content>
                </Tab>
            </tabs>

            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </TabPane>
    </center>
</BorderPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.VBox?>
<BorderPane prefHeight="600" prefWidth="900" stylesheets="@/css/manager-main.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.zlagoda.controller.ManagerMainController">
    <top>
        <BorderPane style="-fx-padding: 10;">
            <left>
               <VBox>
                   <Label text="ZLAGODA" />
                   <Label text="мініспермаркет" />
                </VBox>
            </left>
            <right>
                <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                    <image>
                        <Image url="@/images/black-cat-icon.png"/>
                    </image>
                </ImageView>
            </right>
        </BorderPane>
    </top>
   <center>
            <TabPane side="LEFT" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
                <tabs>
                    <Tab text="Працівники">
                        <content>
                            <fx:include source="manager/employees.fxml"/>
                        </content>
                    </Tab>
                    <Tab text="Клієнти">
                        <content>
                            <fx:include source="manager/clients.fxml"/>
                        </content>
                    </Tab>
                    <Tab text="Товари">
                        <content>
                            <fx:include source="manager/products.fxml"/>
                        </content>
                    </Tab>
                    <Tab text="Чеки">
                        <content>
                            <fx:include source="manager/checks.fxml"/>
                        </content>
                    </Tab>
                    <Tab text="Звіти">
                        <content>
                            <fx:include source="manager/reports.fxml"/>
                        </content>
                    </Tab>
                </tabs>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
            </TabPane>
   </center>
    </BorderPane>

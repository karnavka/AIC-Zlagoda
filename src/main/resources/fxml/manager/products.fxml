<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0"
      style="-fx-background-color: white;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.zlagoda.controller.manager.ManagerProductsController">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="📦 ТОВАРИ">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>

        <Region HBox.hgrow="ALWAYS"/>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <TextField fx:id="productSearchField"
                       prefHeight="30.0"
                       prefWidth="250.0"
                       promptText="ПОШУК ТОВАРУ (UPC)..."/>
        </HBox>
    </HBox>

    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
        <VBox spacing="10.0" prefWidth="380.0">
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="КАТЕГОРІЇ"
                       style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="showAllCategoriesButton"
                        text="ПОКАЗАТИ ВСІ"
                        onAction="#showAllCategories"
                        style="-fx-background-color: transparent; -fx-text-fill: #e09ed4; -fx-font-size: 12px; -fx-underline: true;"/>
            </HBox>
            <TableView fx:id="categoriesTable" VBox.vgrow="ALWAYS">
                <VBox.margin>
                    <Insets top="9.0" />
                </VBox.margin>
                <columns>
                    <TableColumn fx:id="catIdColumn" text="ID" prefWidth="70.0"/>
                    <TableColumn fx:id="catNameColumn" text="НАЗВА КАТЕГОРІЇ" prefWidth="280.0"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <placeholder>
                    <Label text="Категорії відсутні"/>
                </placeholder>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                <Button fx:id="addCategoryButton"
                        text="ДОДАТИ КАТЕГОРІЮ"/>
            </HBox>

            <VBox fx:id="editCategoryBox"
                  visible="false"
                  managed="false"
                  spacing="12.0"
                  style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15; -fx-background-color: #fafafa;">
                <Label text="РЕДАГУВАННЯ / ДОДАВАННЯ КАТЕГОРІЇ"
                       style="-fx-font-weight: bold; -fx-font-style: italic; -fx-text-fill: #666666;"/>
                <TextField fx:id="categoryNameField"
                           promptText="Назва категорії..."/>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <Button fx:id="deleteCategoryButton"
                            text="ВИДАЛИТИ"
                            visible="false"
                            managed="false"
                            onAction="#deleteCategory"
                            style="-fx-background-color: #ffcccc; -fx-text-fill: #cc0000; -fx-font-weight: bold;"/>
                    <Button fx:id="cancelCategoryEdit" text="СКАСУВАТИ"/>
                    <Button fx:id="saveCategoryButton"
                            text="ЗБЕРЕГТИ"
                            style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Права частина: товари -->
        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <Label text="ТОВАРИ"
                       style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="filterComboBox" prefWidth="150.0">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Усі"/>
                            <String fx:value="Наявні"/>
                            <String fx:value="Акційні"/>
                            <String fx:value="Не акційні"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </HBox>

            <TableView fx:id="productsTable" VBox.vgrow="ALWAYS">
                <VBox.margin>
                    <Insets top="9.0" />
                </VBox.margin>                <columns>
                    <TableColumn fx:id="upcColumn" text="UPC" prefWidth="120.0"/>
                    <TableColumn fx:id="productNameColumn" text="НАЗВА" prefWidth="240.0"/>
                    <TableColumn fx:id="priceColumn" text="ЦІНА" prefWidth="100.0"/>
                    <TableColumn fx:id="amountColumn" text="К-СТЬ" prefWidth="100.0"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <placeholder>
                    <Label text="Оберіть категорію або скористайтеся пошуком"/>
                </placeholder>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                <Button text="ДОДАТИ ТОВАР"
                        onAction="#addProduct"/>
            </HBox>

            <VBox fx:id="editProductBox"
                  visible="false"
                  managed="false"
                  spacing="12.0"
                  style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15; -fx-background-color: #fafafa;">

                <Label text="РЕДАГУВАННЯ / ДОДАВАННЯ ТОВАРУ"
                       style="-fx-font-weight: bold; -fx-font-style: italic; -fx-text-fill: #666666;"/>
                <GridPane hgap="10.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints minWidth="110.0"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints minWidth="110.0"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <children>
                        <Label text="UPC :" GridPane.rowIndex="0"/>
                        <TextField fx:id="editUpcField"
                                   promptText="UPC"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="0"/>

                        <Label text="UPC акційного :" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <TextField fx:id="upcPromField"
                                   promptText="UPC_prom"
                                   GridPane.columnIndex="3"
                                   GridPane.rowIndex="0"/>

                        <Label text="НАЗВА :" GridPane.rowIndex="1"/>
                        <TextField fx:id="editProductNameField"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1"
                                   GridPane.columnSpan="3"/>

                        <Label text="ВИРОБНИК :" GridPane.rowIndex="2"/>
                        <TextField fx:id="editManufacturerField"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="2"
                                   GridPane.columnSpan="3"/>

                        <Label text="ХАРАКТЕРИСТИКИ :" GridPane.rowIndex="3"/>
                        <TextField fx:id="editCharacteristicsField"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="3"
                                   GridPane.columnSpan="3"/>

                        <Label text="ЦІНА :" GridPane.rowIndex="4"/>
                        <TextField fx:id="editPriceField"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="4"/>

                        <Label text="К-СТЬ :" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
                        <TextField fx:id="editAmountField"
                                   GridPane.columnIndex="3"
                                   GridPane.rowIndex="4"/>

                        <CheckBox fx:id="promotionalCheckBox"
                                  text="Акційний товар"
                                  GridPane.rowIndex="5"
                                  GridPane.columnSpan="4"/>
                    </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="deleteProductButton"
                            text="ВИДАЛИТИ"
                            prefHeight="35.0"
                            prefWidth="120.0"
                            onAction="#deleteProduct"
                            style="-fx-background-color: #ffcccc; -fx-text-fill: #cc0000; -fx-font-weight: bold;"/>
                    <Button text="СКАСУВАТИ"
                            onAction="#cancelProductEdit"/>
                    <Button text="ЗБЕРЕГТИ"
                            onAction="#saveProductEdit"
                            style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
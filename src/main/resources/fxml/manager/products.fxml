<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox spacing="15.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.zlagoda.controller.manager.ManagerProductsController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="📦 ТОВАРИ">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <TextField fx:id="productSearchField" prefHeight="30.0" prefWidth="250.0" promptText="ПОШУК ТОВАРУ (UPC)..."/>
            <Button fx:id="searchProductButton" mnemonicParsing="false" prefHeight="30.0" text="ЗНАЙТИ"/>
        </HBox>
    </HBox>

    <HBox spacing="20.0" VBox.vgrow="ALWAYS">

        <VBox spacing="10.0" prefWidth="400.0">
            <Label text="КАТЕГОРІЇ" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>

            <TableView fx:id="categoriesTable" VBox.vgrow="ALWAYS">
                <VBox.margin>
                    <Insets top="8.0" />
                </VBox.margin>
                <columns>
                    <TableColumn fx:id="catIdColumn" prefWidth="60.0" text="ID" />
                    <TableColumn fx:id="catNameColumn" prefWidth="300.0" text="НАЗВА КАТЕГОРІЇ" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <Button fx:id="addCategoryButton" text="ДОДАТИ"/>
            </HBox>

            <VBox fx:id="editCategoryBox" managed="false" visible="false" spacing="15.0"
                  style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15; -fx-background-color: #fafafa;">
                <Label text="РЕДАГУВАННЯ / ДОДАВАННЯ КАТЕГОРІЇ" style="-fx-font-weight: bold; -fx-font-style: italic; -fx-text-fill: #666666;"/>
                <TextField fx:id="categoryNameField" promptText="Назва категорії..."/>
                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <Button fx:id="cancelCategoryEdit" text="СКАСУВАТИ"/>
                    <Button fx:id="saveCategoryButton" text="ЗБЕРЕГТИ" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </VBox>

        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <Label text="ТОВАРИ" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="СОРТУВАТИ:"/>
                <ComboBox fx:id="filterComboBox" prefWidth="120.0" value="Усі">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Усі" />
                            <String fx:value="Наявні" />
                            <String fx:value="Акційні" />
                            <String fx:value="Не акційні" />
                        </FXCollections>
                    </items>
                </ComboBox>
            </HBox>

            <TableView fx:id="productsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="upcColumn" prefWidth="100.0" text="UPC" />
                    <TableColumn fx:id="productNameColumn" prefWidth="200.0" text="НАЗВА" />
                    <TableColumn fx:id="priceColumn" prefWidth="80.0" text="ЦІНА" />
                    <TableColumn fx:id="amountColumn" prefWidth="80.0" text="К-СТЬ" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <placeholder>
                    <Label text="Оберіть категорію або скористайтеся пошуком"/>
                </placeholder>
            </TableView>

            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <Button fx:id="addProductButton" text="ДОДАТИ"/>
            </HBox>

            <VBox fx:id="editProductBox" managed="false" visible="false" spacing="10.0"
                  style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15; -fx-background-color: #fafafa;">
                <Label text="РЕДАГУВАННЯ / ДОДАВАННЯ ТОВАРУ" style="-fx-font-weight: bold; -fx-font-style: italic; -fx-text-fill: #666666;"/>
                <GridPane hgap="10.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints minWidth="80.0"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints minWidth="80.0"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <children>
                        <Label text="НАЗВА :"/>
                        <TextField fx:id="editProductNameField" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
                        <Label text="ЦІНА :" GridPane.rowIndex="1"/>
                        <TextField fx:id="editPriceField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label text="К-СТЬ :" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <TextField fx:id="editAmountField" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                    </children>
                </GridPane>
                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="deleteClientButton"
                            prefHeight="35.0" prefWidth="120.0"
                            style="-fx-background-color: #ffcccc; -fx-text-fill: #cc0000; -fx-font-weight: bold;"
                            text="ВИДАЛИТИ"/>
                    <Button fx:id="cancelProductEdit" text="СКАСУВАТИ"/>
                    <Button fx:id="saveProductButton" text="ЗБЕРЕГТИ" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
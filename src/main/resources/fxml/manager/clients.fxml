<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.zlagoda.controller.manager.ManagerClientsController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="👥 КЛІЄНТИ">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <TextField fx:id="lastNameSearchField" prefHeight="30.0" prefWidth="350.0" promptText="ПРІЗВИЩЕ..." HBox.hgrow="ALWAYS"/>

        <Label text="Відсоток знижки :"/>
        <TextField fx:id="discountSearchField" prefHeight="30.0" prefWidth="60.0" promptText="0" alignment="CENTER"/>
        <Label text="\%"/>

        <Button fx:id="searchButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="100.0" text="ЗНАЙТИ"/>
        <Button fx:id="clearButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="100.0" text="ОЧИСТИТИ"/>
    </HBox>

    <TableView fx:id="clientsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="cardNumberColumn" prefWidth="120.0" text="НОМЕР КАРТИ" />
            <TableColumn fx:id="pibColumn" prefWidth="300.0" text="ПІБ КЛІЄНТА" />
            <TableColumn fx:id="phoneColumn" prefWidth="150.0" text="ТЕЛЕФОН" />
            <TableColumn fx:id="percentColumn" prefWidth="80.0" text="\% ЗНИЖКИ" />
        </columns>
        <placeholder>
            <Label text="По дефолту всі клієнти, інакше - результат пошуку"/>
        </placeholder>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button fx:id="deleteClientButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="120.0"
                style="-fx-background-color: #ffcccc; -fx-text-fill: #cc0000; -fx-font-weight: bold;" text="ВИДАЛИТИ"/>
        <Button fx:id="editClientButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="120.0" text="РЕДАГУВАТИ"/>
        <Button fx:id="addClientButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="120.0" text="ДОДАТИ +"/>
    </HBox>

    <VBox fx:id="editClientBox" managed="false" spacing="20.0"
          style="-fx-border-color: #cccccc; -fx-border-radius: 8; -fx-padding: 25; -fx-background-color: #fafafa;"
          visible="false">

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="ВІДКРИВАЄТЬСЯ ПРИ ДОДАВАННІ КЛІЄНТА І ПРИ КЛІКУ НА ТАБЛИЦЮ ДЛЯ РЕДАГУВАННЯ"
                   mouseTransparent="true"
                   style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #666666; -fx-opacity: 1.0; -fx-font-style: italic;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="cancelEditButton" mnemonicParsing="false" text="СКАСУВАТИ"/>
        </HBox>

        <GridPane hgap="15.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints minWidth="120.0" prefWidth="120.0"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="150.0"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="150.0"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="150.0"/>
            </columnConstraints>
            <children>
                <Label text="НОМЕР КАРТИ :" GridPane.rowIndex="0"/>
                <TextField fx:id="cardNumberField" promptText="Введіть номер..." prefHeight="30.0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="ПІБ КЛІЄНТА :" GridPane.rowIndex="1"/>
                <TextField fx:id="lastNameField" promptText="Прізвище..." prefHeight="30.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <TextField fx:id="firstNameField" promptText="Ім'я..." prefHeight="30.0" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <TextField fx:id="patronymicField" promptText="По-батькові..." prefHeight="30.0" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                <Label text="ТЕЛЕФОН :" GridPane.rowIndex="2"/>
                <HBox alignment="CENTER_LEFT" spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <Label text="+380" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="phoneField" promptText="телефон..." prefHeight="30.0" HBox.hgrow="ALWAYS"/>
                </HBox>

                <Label text="АДРЕСА :" GridPane.rowIndex="3"/>
                <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="3">
                    <TextField fx:id="cityField" promptText="Місто" prefHeight="30.0" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="streetField" promptText="Вулиця" prefHeight="30.0" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="zipField" promptText="Індекс" prefHeight="30.0" prefWidth="100.0"/>
                </HBox>
            </children>
        </GridPane>

        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label text="ВІДСОТОК ЗНИЖКИ :"/>
            <TextField fx:id="discountPercentField" prefWidth="60.0" prefHeight="30.0" promptText="0" alignment="CENTER"/>
            <Label text="\%" />
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="saveClientButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="150.0"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"
                    text="ЗБЕРЕГТИ"/>
        </HBox>
    </VBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.zlagoda.controller.manager.ManagerEmployeesController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="👤 ПРАЦІВНИКИ">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <TextField fx:id="lastNameSearchField" prefHeight="30.0" prefWidth="400.0" promptText="ПРІЗВИЩЕ..." HBox.hgrow="ALWAYS"/>
        <Button fx:id="searchButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="100.0" text="ЗНАЙТИ"/>
        <Button fx:id="clearButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="100.0" text="ОЧИСТИТИ"/>
    </HBox>

    <TableView fx:id="employeesTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID" />
            <TableColumn fx:id="surnameColumn" prefWidth="150.0" text="ПРІЗВИЩЕ" />
            <TableColumn fx:id="nameColumn" prefWidth="150.0" text="ІМ'Я" />
            <TableColumn fx:id="roleColumn" prefWidth="120.0" text="РОЛЬ" />
            <TableColumn fx:id="phoneColumn" prefWidth="150.0" text="ТЕЛЕФОН" />
            <TableColumn fx:id="salaryColumn" prefWidth="100.0" text="ЗАРПЛАТА" />
        </columns>
        <placeholder>
            <Label text="Працівників не знайдено..."/>
        </placeholder>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button fx:id="deleteEmployeeButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="120.0"
                style="-fx-background-color: #ffcccc; -fx-text-fill: #cc0000; -fx-font-weight: bold;" text="ВИДАЛИТИ"/>
        <Button fx:id="editEmployeeButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="120.0" text="РЕДАГУВАТИ"/>
        <Button fx:id="addEmployeeButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="120.0" text="ДОДАТИ +"/>
    </HBox>

    <VBox fx:id="editEmployeeBox" managed="false" spacing="20.0"
          style="-fx-border-color: #cccccc; -fx-border-radius: 8; -fx-padding: 25; -fx-background-color: #fafafa;"
          visible="false">

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="ДОДАВАННЯ ПРАЦІВНИКА АБО РЕДАГУВАННЯ ІНФОРМАЦІЇ ПРО НЬОГО"
                   mouseTransparent="true"
                   style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #666666; -fx-opacity: 1.0; -fx-font-style: italic;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="cancelEditButton" mnemonicParsing="false" text="СКАСУВАТИ"/>
        </HBox>

        <GridPane hgap="20.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints minWidth="120.0" prefWidth="120.0"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="150.0"/>
                <ColumnConstraints minWidth="100.0" prefWidth="100.0"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="150.0"/>
            </columnConstraints>
            <children>
                <Label text="ID ПРАЦІВНИКА :" GridPane.rowIndex="0"/>
                <TextField fx:id="employeeIdField" promptText="ID..." prefHeight="30.0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="ПІБ :" GridPane.rowIndex="1"/>
                <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="1">
                    <TextField fx:id="lastNameField" promptText="Прізвище" prefHeight="30.0" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="firstNameField" promptText="Ім'я" prefHeight="30.0" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="patronymicField" promptText="По-батькові" prefHeight="30.0" HBox.hgrow="ALWAYS"/>
                </HBox>

                <Label text="ТЕЛЕФОН :" GridPane.rowIndex="2"/>
                <TextField fx:id="phoneField" promptText="+380..." prefHeight="30.0" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="ЗАРПЛАТА :" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                <TextField fx:id="salaryField" promptText="Сума..." prefHeight="30.0" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                <Label text="АДРЕСА :" GridPane.rowIndex="3"/>
                <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="3">
                    <TextField fx:id="cityField" promptText="Місто" prefHeight="30.0" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="streetField" promptText="Вулиця" prefHeight="30.0" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="zipField" promptText="Індекс" prefHeight="30.0" prefWidth="100.0"/>
                </HBox>
            </children>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <Button fx:id="saveEmployeeButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="150.0"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"
                    text="ЗБЕРЕГТИ"/>
        </HBox>
    </VBox>
</VBox>
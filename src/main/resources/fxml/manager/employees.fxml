<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="8.0" style="-fx-background-color: white;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.zlagoda.controller.manager.ManagerEmployeesController">

    <padding>
        <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <TextField fx:id="lastNameSearchField" prefHeight="30.0" prefWidth="400.0"
                   promptText="ПРІЗВИЩЕ..." HBox.hgrow="ALWAYS"/>
        <Button text="ЗНАЙТИ" prefHeight="30.0" prefWidth="100.0" onAction="#searchEmployee"/>
        <Button text="ОЧИСТИТИ" prefHeight="30.0" prefWidth="100.0" onAction="#clearEmployees"/>
    </HBox>

    <TableView fx:id="employeesTable" VBox.vgrow="ALWAYS" prefHeight="120.0" minHeight="100.0">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50.0"/>
            <TableColumn fx:id="surnameColumn" text="Прізвище" prefWidth="100.0"/>
            <TableColumn fx:id="nameColumn" text="Ім'я" prefWidth="100.0"/>
            <TableColumn fx:id="roleColumn" text="Посада" prefWidth="100.0"/>
            <TableColumn fx:id="phoneColumn" text="Телефон" prefWidth="110.0"/>
            <TableColumn fx:id="salaryColumn" text="Зарплата" prefWidth="80.0"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button text="ДОДАТИ ПРАЦІВНИКА +" onAction="#addEmployee"
                prefHeight="28.0" prefWidth="180.0"/>
    </HBox>

    <VBox fx:id="editEmployeeBox" spacing="5.0" managed="false" visible="false">
        <Separator/>
        <Label text="ВІКНО ДОДАВАННЯ / РЕДАГУВАННЯ" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>

        <GridPane hgap="10.0" vgap="5.0">
            <columnConstraints>
                <ColumnConstraints minWidth="120.0" prefWidth="125.0"/>
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints minWidth="120.0" prefWidth="125.0"/>
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <children>
                <Label text="ID ПРАЦІВНИКА:" GridPane.rowIndex="0"/>
                <TextField fx:id="employeeIdField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="РОЛЬ:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <ComboBox fx:id="roleComboBox" maxWidth="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                <Label text="ПРІЗВИЩЕ:" GridPane.rowIndex="1"/>
                <TextField fx:id="lastNameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="ІМ'Я:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <TextField fx:id="firstNameField" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                <Label text="ПО-БАТЬКОВІ:" GridPane.rowIndex="2"/>
                <TextField fx:id="patronymicField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="ТЕЛЕФОН:" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                <TextField fx:id="phoneField" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                <Label text="ЗАРПЛАТА:" GridPane.rowIndex="3"/>
                <TextField fx:id="salaryField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="ІНДЕКС:" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                <TextField fx:id="zipField" GridPane.columnIndex="3" GridPane.rowIndex="3"/>

                <Label text="МІСТО:" GridPane.rowIndex="4"/>
                <TextField fx:id="cityField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                <Label text="ВУЛИЦЯ:" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
                <TextField fx:id="streetField" GridPane.columnIndex="3" GridPane.rowIndex="4"/>

                <Label text="НАРОДЖЕННЯ:" GridPane.rowIndex="5"/>
                <DatePicker fx:id="birthDatePicker" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                <Label text="СТАРТ РОБОТИ:" GridPane.columnIndex="2" GridPane.rowIndex="5"/>
                <DatePicker fx:id="startDatePicker" maxWidth="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="5"/>
            </children>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button fx:id="deleteClientButton"
                    prefHeight="35.0" prefWidth="120.0"
                    style="-fx-background-color: #ffcccc; -fx-text-fill: #cc0000; -fx-font-weight: bold;"
                    text="ВИДАЛИТИ"/>
            <Button fx:id="saveEmployeeButton" text="ЗБЕРЕГТИ" onAction="#saveEmployee"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" prefHeight="25.0" prefWidth="120.0"/>
            <Button text="ЗАКРИТИ" onAction="#cancelEdit" prefHeight="25.0" prefWidth="90.0"/>
        </HBox>
    </VBox>
</VBox>
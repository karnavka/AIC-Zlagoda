<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<VBox spacing="15.0" style="-fx-background-color: white;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.zlagoda.controller.manager.ManagerEmployeesController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="👤 ПРАЦІВНИКИ">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <TextField fx:id="lastNameSearchField" prefHeight="30.0" prefWidth="400.0"
                   promptText="ПРІЗВИЩЕ..." HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="roleSearchComboBox" prefHeight="30.0" prefWidth="150.0" promptText="Всі ролі">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Всі ролі"/>
                    <String fx:value="manager"/>
                    <String fx:value="cashier"/>
                </FXCollections>
            </items>
        </ComboBox>
        <Button text="ЗНАЙТИ" prefHeight="30.0" prefWidth="100.0" onAction="#searchEmployee"/>
        <Button text="ОЧИСТИТИ" prefHeight="30.0" prefWidth="100.0" onAction="#clearEmployees"/>
    </HBox>

    <TableView fx:id="employeesTable" prefHeight="320.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID"/>
            <TableColumn fx:id="surnameColumn" text="ПРІЗВИЩЕ"/>
            <TableColumn fx:id="nameColumn" text="ІМ'Я"/>
            <TableColumn fx:id="roleColumn" text="РОЛЬ"/>
            <TableColumn fx:id="phoneColumn" text="ТЕЛЕФОН"/>
            <TableColumn fx:id="salaryColumn" text="ЗАРПЛАТА"/>
        </columns>
        <placeholder>
            <Label text="Працівників не знайдено..."/>
        </placeholder>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button fx:id="addEmployeeButton" text="ДОДАТИ +" prefHeight="30.0" prefWidth="120.0"
                onAction="#addEmployee"/>
    </HBox>

    <VBox fx:id="editEmployeeBox"
          visible="false" managed="false"
          spacing="20.0"
          style="-fx-border-color: #cccccc; -fx-border-radius: 8; -fx-padding: 25; -fx-background-color: #fafafa;">

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="ДОДАВАННЯ АБО РЕДАГУВАННЯ ПРАЦІВНИКА"
                   style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #666666; -fx-font-style: italic;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="СКАСУВАТИ" onAction="#cancelEdit"/>
        </HBox>

        <GridPane hgap="20.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints minWidth="140.0" prefWidth="140.0"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="180.0"/>
                <ColumnConstraints minWidth="140.0" prefWidth="140.0"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="180.0"/>
            </columnConstraints>

            <children>
                <Label text="ID ПРАЦІВНИКА :" GridPane.rowIndex="0"/>
                <TextField fx:id="employeeIdField" promptText="ID..."
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="РОЛЬ :" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <ComboBox fx:id="roleComboBox"
                          GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                <Label text="ПРІЗВИЩЕ :" GridPane.rowIndex="1"/>
                <TextField fx:id="lastNameField" promptText="Прізвище"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="ІМ'Я :" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <TextField fx:id="firstNameField" promptText="Ім'я"
                           GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                <Label text="ПО-БАТЬКОВІ :" GridPane.rowIndex="2"/>
                <TextField fx:id="patronymicField" promptText="По-батькові"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="ТЕЛЕФОН :" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                <TextField fx:id="phoneField" promptText="+380..."
                           GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                <Label text="ЗАРПЛАТА :" GridPane.rowIndex="3"/>
                <TextField fx:id="salaryField" promptText="Сума..."
                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="ІНДЕКС :" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                <TextField fx:id="zipField" promptText="Індекс"
                           GridPane.columnIndex="3" GridPane.rowIndex="3"/>

                <Label text="МІСТО :" GridPane.rowIndex="4"/>
                <TextField fx:id="cityField" promptText="Місто"
                           GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                <Label text="ВУЛИЦЯ :" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
                <TextField fx:id="streetField" promptText="Вулиця"
                           GridPane.columnIndex="3" GridPane.rowIndex="4"/>

                <Label text="ДАТА НАРОДЖЕННЯ :" GridPane.rowIndex="5"/>
                <DatePicker fx:id="birthDatePicker"
                            GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                <Label text="ДАТА ПОЧАТКУ РОБОТИ :" GridPane.columnIndex="2" GridPane.rowIndex="5"/>
                <DatePicker fx:id="startDatePicker"
                            GridPane.columnIndex="3" GridPane.rowIndex="5"/>
            </children>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="deleteEmployeeButton"
                    text="ВИДАЛИТИ"
                    prefHeight="35.0" prefWidth="120.0"
                    style="-fx-background-color: #ffcccc; -fx-text-fill: #cc0000; -fx-font-weight: bold;"
                    onAction="#deleteEmployee"/>
            <Button fx:id="saveEmployeeButton"
                    text="ЗБЕРЕГТИ"
                    prefHeight="35.0" prefWidth="150.0"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"
                    onAction="#saveEmployee"/>
        </HBox>
    </VBox>
</VBox>
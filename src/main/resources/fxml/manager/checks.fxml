<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.zlagoda.controller.manager.ManagerChecksController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="📑 ЧЕКИ">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Label text="ЧЕКИ" style="-fx-font-weight: bold;"/>

        <Label text="З"/>
        <DatePicker fx:id="startDatePicker" prefWidth="130.0" promptText="ДАТА"/>

        <Label text="ПО"/>
        <DatePicker fx:id="endDatePicker" prefWidth="130.0" promptText="ДАТА"/>

        <ComboBox fx:id="cashierComboBox" prefWidth="150.0" promptText="Усі (касири)"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Button fx:id="searchButton" mnemonicParsing="false" prefWidth="100.0" text="ЗНАЙТИ"/>
    </HBox>

    <VBox spacing="5.0" VBox.vgrow="ALWAYS">
        <TableView fx:id="checksTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="numberColumn" prefWidth="100.0" text="НОМЕР" />
                <TableColumn fx:id="dateColumn" prefWidth="150.0" text="ДАТА" />
                <TableColumn fx:id="cashierColumn" prefWidth="200.0" text="КАСИР" />
                <TableColumn fx:id="totalColumn" prefWidth="120.0" text="СУМА" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <placeholder>
                <Label text="Результати пошуку за період"/>
            </placeholder>
        </TableView>

        <HBox alignment="CENTER_RIGHT">
            <Label text="ЗАГАЛЬНА СУМА: " style="-fx-font-weight: bold;"/>
            <Label fx:id="totalSumLabel" text="0.00" style="-fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
        </HBox>
    </VBox>

    <VBox fx:id="detailsBox" managed="false" visible="false" spacing="10.0"
          style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15; -fx-background-color: #fafafa;">

        <Label text="ДЕТАЛІ ОБРАНОГО ЧЕКУ" style="-fx-font-weight: bold; -fx-text-fill: #555555;"/>

        <TableView fx:id="checkItemsTable" prefHeight="150.0">
            <columns>
                <TableColumn fx:id="itemNameColumn" prefWidth="300.0" text="ТОВАР" />
                <TableColumn fx:id="itemQuantityColumn" prefWidth="80.0" text="К-СТЬ" />
                <TableColumn fx:id="itemPriceColumn" prefWidth="100.0" text="ЦІНА" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button fx:id="deleteCheckButton" mnemonicParsing="false"
                    style="-fx-background-color: #ffcccc; -fx-text-fill: #cc0000;" text="ВИДАЛИТИ ЧЕК"/>
        </HBox>
    </VBox>

</VBox>